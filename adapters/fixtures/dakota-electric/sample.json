 "raw": "\r\n\r\n<!DOCTYPE html>\r\n\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\r\n<head><meta name=\"viewport\" content=\"initial-scale=1.0\" /><meta charset=\"UTF-8\" /><title>\r\n\tDakota Electric Association Outage Map\r\n</title><meta name=\"description\" content=\"Dakota Electric Association Outage Map\" /><link rel=\"stylesheet\" href=\"https://js.arcgis.com/4.23/esri/themes/light/main.css\" />\r\n    <script src=\"https://js.arcgis.com/4.23/\"></script>\r\n\r\n    <link rel=\"stylesheet\" type=\"text/css\" media=\"screen and (max-width: 480px)\" href=\"styles/esri_map_style_mobile.css?v=23\" /><link rel=\"stylesheet\" type=\"text/css\" media=\"screen and (max-width: 768px) and (min-width: 481px)\" href=\"styles/esri_map_style_tablet.css?v=23\" /><link rel=\"stylesheet\" type=\"text/css\" media=\"screen and (min-width: 769px)\" href=\"styles/esri_map_style_desktop.css?v=23\" /> \r\n\t\t\r\n    <script>\r\n\t\r\n        require([\r\n            \"esri/Map\",\r\n            \"esri/views/MapView\",\r\n            \"esri/Graphic\",\r\n            \"esri/core/watchUtils\",\r\n            \"esri/layers/KMLLayer\"\r\n        ], function (Map, MapView, Graphic, watchUtils, KMLLayer) {\r\n\r\n            var map = new Map({\r\n                basemap: \"streets\"\r\n            });\r\n\r\n            var zoom = DetermineMapZoom();\r\n\r\n            var view = new MapView({\r\n                container: \"map_canvas\",\r\n                map: map,\r\n                popup: {\r\n                    dockEnabled: false,\r\n                    dockOptions: {\r\n                        // Disables the dock button from the popup\r\n                        buttonEnabled: false,\r\n                        // Ignore the default sizes that trigger responsive docking\r\n                        breakpoint: false\r\n                    },\r\n\t\t\t\tcollapseEnabled: false                \r\n\t\t\t\t},\r\n                zoom: zoom,\t\t\t\t\r\n                center: [-93, 44.65],\r\n\t\t\t\tconstraints: {\r\n\t\t\t\t\tmaxZoom: 14\r\n\t\t\t\t\t}\r\n            });\r\n\t\t\t\r\n\t\t\t// ***************************************************************************************\r\n\t\t\t// Service Area KML\r\n\t\t\t\r\n\t\t\tvar ServiceArea = new KMLLayer({\r\n\t\t\t\turl: \"https://amp.dakotaelectric.com/outagemap/ServiceArea.kml\"\r\n            });\t\t\t\r\n\r\n            map.add(ServiceArea);\r\n\r\n\t\t\r\n\t\t\t// ***************************************************************************************\r\n\t\t\t// Cone Graphics\r\n\t\t\r\n\t\t\tvar greenCone = {\r\n\t\t\t\ttype: \"picture-marker\",\r\n\t\t\t\turl: \"images/Cone_Green_36.png\",\r\n\t\t\t\twidth: \"30px\",\r\n                height: \"30px\",\r\n\t\t\t};\r\n\t\t\t\r\n\t\t\tvar blueCone = {\r\n\t\t\t\ttype: \"picture-marker\",\r\n\t\t\t\turl: \"images/Cone_Blue_36.png\",\r\n\t\t\t\twidth: \"30px\",\r\n\t\t\t\theight: \"30px\"\r\n\t\t\t};\r\n\t\t\t\r\n\t\t\tvar yellowCone = {\r\n\t\t\t\ttype: \"picture-marker\",\r\n\t\t\t\turl: \"images/Cone_Yellow_36.png\",\r\n\t\t\t\twidth: \"30px\",\r\n\t\t\t\theight: \"30px\"\r\n\t\t\t};\r\n\t\t\t\r\n\t\t\tvar orangeCone = {\r\n\t\t\t\ttype: \"picture-marker\",\r\n\t\t\t\turl: \"images/Cone_Orange_36.png\",\r\n\t\t\t\twidth: \"30px\",\r\n\t\t\t\theight: \"30px\"\r\n\t\t\t};\t\t\t\r\n\t\t\t\r\n\t\t\tvar redCone = {\r\n\t\t\t\ttype: \"picture-marker\",\r\n\t\t\t\turl: \"images/Cone_Red_36.png\",\r\n\t\t\t\twidth: \"30px\",\r\n\t\t\t\theight: \"30px\"\r\n            };\r\n\r\n\t\t\tvar houseCone = {\r\n\t\t\t\ttype: \"picture-marker\",\r\n\t\t\t\turl: \"images/house.png\",\r\n\t\t\t\twidth: \"30px\",\r\n\t\t\t\theight: \"30px\"\r\n            };\r\n\r\n\t\t\tfunction DetermineMapZoom()\r\n\t\t\t{\r\n                var width = (window.innerWidth > 0) ? window.innerWidth : screen.width;\r\n                var height = (window.innerHeight > 0) ? window.innerHeight : screen.height;\r\n\r\n//  \t\t\t  window.alert(\"width: \" + width + \" Height: \" + height);\r\n\t\t\t\t\t\r\n\t\t\t\tif (width >= 769) {\r\n\t\t\t\t    return 11;\r\n\t\t\t\t}\r\n\t\t\t\telse if (width >= 480) {\r\n\t\t\t\t    return 10;\r\n\t\t\t\t}\r\n\t\t\t\telse {\r\n\t\t\t\t    return 9;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\tfunction AddOutagePoint(x, y, title, cone, info)\r\n\t\t\t{\r\n\t\t\t\t// ***************************************************************************************\r\n\t\t\t\t// Create Graphic\r\n\t\t\t\tvar outageCone;\r\n\t\t\t\t\r\n\t\t\t\tif(cone == 'greenCone')\r\n\t\t\t\t{\r\n\t\t\t\t\t\toutageCone = greenCone;\r\n\t\t\t\t}\r\n\t\t\t\telse if (cone == 'blueCone')\r\n\t\t\t\t{\r\n\t\t\t\t\t\toutageCone = blueCone;\r\n\t\t\t\t}\r\n\t\t\t\telse if (cone == 'yellowCone')\r\n\t\t\t\t{\r\n\t\t\t\t\t\toutageCone = yellowCone;\r\n\t\t\t\t}\r\n\t\t\t\telse if (cone == 'orangeCone')\r\n\t\t\t\t{\r\n\t\t\t\t\t\toutageCone = orangeCone;\r\n\t\t\t\t}\r\n\t\t\t\telse if (cone == 'redCone')\r\n\t\t\t\t{\r\n\t\t\t\t\t\toutageCone = redCone;\r\n\t\t\t\t}\r\n\t\t\t\telse if (cone == 'houseCone')\r\n\t\t\t\t{\r\n\t\t\t\t\t\toutageCone = houseCone;\r\n\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\tvar pointGraphic = new Graphic({\r\n\t\t\t\t\tgeometry: {\r\n                        type: \"point\",\r\n\t\t\t\t\t    longitude: x,\r\n                        latitude: y,\r\n                        spatialReference: { wkid: 103726 }\r\n                    },\r\n\t\t\t\t\tsymbol: outageCone,\r\n\t\t\t\t\tpopupTemplate : {\r\n\t\t\t\t\t\ttitle: title,\r\n\t\t\t\t\t\tcontent : info\r\n                    }\r\n                });\r\n                \r\n\t\t\t\t\r\n\t\t\t\t// ***************************************************************************************\r\n\t\t\t\t// Add Graphic to View\r\n\t\t\t\t\r\n\t\t\t\tview.graphics.add(pointGraphic);\r\n\t\t\t\t\r\n\t\t\t\t// ***************************************************************************************\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\tGPSData.forEach(addGPSData);\r\n\r\n\t\t\tfunction addGPSData(item, index) { \r\n\t\t\t\t\r\n\t\t\t\tvar xCoord = item.x;\r\n\t\t\t\tvar yCoord = item.y;\r\n\t\t\t\tvar info = item.info;\r\n                var cone = item.cone;\r\n                var title = item.title;\r\n\r\n\t\t\t\tAddOutagePoint(xCoord, yCoord, title, cone, info);\r\n\t\t\t\t\r\n            }\r\n\r\n            var initialExtent = null;\r\n\r\n            watchUtils.whenTrue(view, \"stationary\", function() {\r\n                    // Get the new extent of the view only when view is stationary.\r\n                if (view.extent) {\r\n                    if (initialExtent == null) {\r\n                        initialExtent = view.extent;\r\n//                        alert(\"Setting Initial Extent\");\r\n                        return;\r\n                    }\r\n                    else {\r\n                        var dirty = false;\r\n\r\n                        if (view.extent.xmin < -10489005) {\r\n                            dirty = true;\r\n                        }\r\n                        if (view.extent.xmax > -10210353) {\r\n                            dirty = true;\r\n                        }\r\n                        if (view.extent.ymin < 5469201) {\r\n                            dirty = true;\r\n                        }\r\n                        if (view.extent.ymax > 5652522) {\r\n                            dirty = true;\r\n                        }\r\n\r\n                        if (dirty == true) {\r\n                            view.goTo(initialExtent);\r\n                        }\r\n                        else {\r\n                            previousExtent = view.extent;\r\n                        }\r\n                    }\r\n                }\r\n             });\r\n        });\r\n    </script>\r\n\r\n</head>\r\n<body>\r\n    <form method=\"post\" action=\"./\" id=\"form1\">\r\n<div class=\"aspNetHidden\">\r\n<input type=\"hidden\" name=\"__VIEWSTATE\" id=\"__VIEWSTATE\" value=\"/wEPDwULLTIwODY2OTk2MDdkZD2wcBKfbJJeeqdo5YY